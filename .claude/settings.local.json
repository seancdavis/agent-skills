{
  "permissions": {
    "allow": [
      "Bash(grep:*)",
      "Bash(tree:*)",
      "WebSearch",
      "Bash(git commit:*)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:neon.com)",
      "WebFetch(domain:docs.astro.build)",
      "Bash(claude /plugin install:*)",
      "Bash(wc:*)",
      "Bash(npx prettier:*)",
      "Bash(claude:*)",
      "Bash(python3:*)",
      "Bash(while read f)",
      "Bash(do jq -r '.permissions.allow[]? // empty' \"$f\" done)",
      "Bash(do jq:*)",
      "Bash(done)",
      "Bash(/dev/null -exec echo \"=== {} ===\" ; -exec cat {} ;)",
      "Bash(gh pr:*)",
      "Bash(brew --version)",
      "Bash(jq --version)",
      "Bash(bash --version)",
      "Bash(brew list *)",
      "Bash(mkdir -p statusline)",
      "Bash(cp ~/.claude/statusline.sh statusline/statusline.sh)",
      "Bash(chmod +x statusline/install.sh statusline/statusline.sh)",
      "Bash(bash -n statusline/install.sh)",
      "Bash(git push *)",
      "Bash(curl -sL https://api.github.com/repos/netlify/context-and-tools/contents/skills)",
      "Bash(curl -sL https://raw.githubusercontent.com/netlify/context-and-tools/main/skills/netlify-functions/SKILL.md)",
      "Bash(awk '{print $2}')",
      "Bash(git checkout *)",
      "Bash(curl *)",
      "Bash(git pull *)",
      "Bash(git stash *)",
      "Bash(awk '/^## Related/,0' __TRACKED_VAR__/SKILL.md)",
      "Bash(gh issue *)",
      "Bash(gh label *)",
      "Bash(git *)"
    ]
  }
}
